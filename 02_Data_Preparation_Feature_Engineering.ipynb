   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Home Credit Default Risk - Data Preparation & Feature Engineering\n",
    "\n",
    "**Phase 2:** Data Cleaning, Imputation, and Feature Engineering  \n",
    "**Date:** January 30, 2026\n",
    "\n",
    "---\n",
    "\n",
    "This notebook implements the data preparation strategy identified in the EDA phase, including:\n",
    "1. Handling sentinel values and data quality issues\n",
    "2. Missing data imputation strategy\n",
    "3. Aggregation and joining of transactional datasets\n",
    "4. Domain-specific feature engineering\n",
    "5. Feature selection and encoding"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Setup & Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
    "from sklearn.impute import SimpleImputer\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Configuration\n",
    "pd.set_option('display.max_columns', None)\n",
    "np.random.seed(42)\n",
    "\n",
    "# Paths\n",
    "data_dir = Path('C:/Users/abdul/Downloads')\n",
    "output_dir = Path('C:/Users/abdul/Downloads/home-credit-project-1')\n",
    "\n",
    "print(\"✓ Libraries loaded successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 1: Load Raw Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load application data\n",
    "train = pd.read_csv(data_dir / 'application_train.csv')\n",
    "test = pd.read_csv(data_dir / 'application_test.csv')\n",
    "\n",
    "print(f\"Train: {train.shape[0]:,} rows × {train.shape[1]} columns\")\n",
    "print(f\"Test:  {test.shape[0]:,} rows × {test.shape[1]} columns\")\n",
    "\n",
    "# Keep test for later\n",
    "test_original = test.copy()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 2: Handle Sentinel Values & Data Quality Issues"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 2: DATA QUALITY - SENTINEL VALUES\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# ===== DAYS_EMPLOYED SENTINEL =====\n",
    "print(\"\\n1. DAYS_EMPLOYED = 365243 (Unemployed/Unknown):\")\n",
    "sentinel_count_train = (train['DAYS_EMPLOYED'] == 365243).sum()\n",
    "sentinel_count_test = (test['DAYS_EMPLOYED'] == 365243).sum()\n",
    "print(f\"   Train: {sentinel_count_train:,} ({100*sentinel_count_train/len(train):.2f}%)\")\n",
    "print(f\"   Test:  {sentinel_count_test:,} ({100*sentinel_count_test/len(test):.2f}%)\")\n",
    "\n",
    "# Replace with NaN\n",
    "train['DAYS_EMPLOYED'] = train['DAYS_EMPLOYED'].replace(365243, np.nan)\n",
    "test['DAYS_EMPLOYED'] = test['DAYS_EMPLOYED'].replace(365243, np.nan)\n",
    "print(\"   ✓ Replaced with NaN\")\n",
    "\n",
    "# ===== ZERO CREDIT AMOUNTS =====\n",
    "print(\"\\n2. AMT_CREDIT = 0 (Suspicious):\")\n",
    "zero_credit_train = (train['AMT_CREDIT'] == 0).sum()\n",
    "zero_credit_test = (test['AMT_CREDIT'] == 0).sum()\n",
    "print(f\"   Train: {zero_credit_train}\")\n",
    "print(f\"   Test:  {zero_credit_test}\")\n",
    "if zero_credit_train > 0:\n",
    "    print(f\"   → Treating as missing data (will impute)\")\n",
    "    train.loc[train['AMT_CREDIT'] == 0, 'AMT_CREDIT'] = np.nan\n",
    "    test.loc[test['AMT_CREDIT'] == 0, 'AMT_CREDIT'] = np.nan\n",
    "\n",
    "print(\"\\n✓ Data quality cleaning complete\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3: Create Missing Indicators"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 3: MISSING INDICATORS\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Identify columns with 30%+ missing data in numeric columns\n",
    "missing_pct = 100 * train.isnull().sum() / len(train)\n",
    "high_missing_numeric = missing_pct[\n",
    "    (missing_pct >= 30) & \n",
    "    (train.dtypes.isin(['int64', 'float64']))\n",
    ].index.tolist()\n",
    "\n",
    "print(f\"\\nNumeric columns with 30%+ missing: {len(high_missing_numeric)}\")\n",
    "\n",
    "# Create missing indicators\n",
    "for col in high_missing_numeric:\n",
    "    if train[col].isnull().sum() > 0:\n",
    "        flag_col = f'{col}_missing'\n",
    "        train[flag_col] = train[col].isnull().astype(int)\n",
    "        test[flag_col] = test[col].isnull().astype(int)\n",
    "        print(f\"  ✓ {flag_col}: {train[flag_col].sum():,} missing flags\")\n",
    "\n",
    "print(f\"\\n✓ Missing indicators created: {len(high_missing_numeric)} flags\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 4: Imputation Strategy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 4: MISSING DATA IMPUTATION\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Get column types\n",
    "numeric_cols = train.select_dtypes(include=['int64', 'float64']).columns.tolist()\n",
    "numeric_cols = [c for c in numeric_cols if not c.endswith('_missing')]\n",
    "\n",
    "categorical_cols = train.select_dtypes(include=['object']).columns.tolist()\n",
    "\n",
    "print(f\"\\nNumeric columns to impute: {len(numeric_cols)}\")\n",
    "print(f\"Categorical columns to impute: {len(categorical_cols)}\")\n",
    "\n",
    "# Remove ID and TARGET from imputation\n",
    "numeric_cols = [c for c in numeric_cols if c not in ['SK_ID_CURR', 'TARGET']]\n",
    "categorical_cols = [c for c in categorical_cols if c != 'SK_ID_CURR']\n",
    "\n",
    "# ===== NUMERIC IMPUTATION (MEDIAN) =====\n",
    "print(\"\\n1. Numeric Imputation (Median):\")\n",
    "numeric_missing = train[numeric_cols].isnull().sum()\n",
    "cols_to_impute_num = numeric_missing[numeric_missing > 0].index.tolist()\n",
    "\n",
    "imputer_numeric = SimpleImputer(strategy='median')\n",
    "train[cols_to_impute_num] = imputer_numeric.fit_transform(train[cols_to_impute_num])\n",
    "test[cols_to_impute_num] = imputer_numeric.transform(test[cols_to_impute_num])\n",
    "\n",
    "print(f\"   Imputed {len(cols_to_impute_num)} numeric columns\")\n",
    "\n",
    "# ===== CATEGORICAL IMPUTATION (MODE / MISSING CATEGORY) =====\n",
    "print(\"\\n2. Categorical Imputation (Mode or 'MISSING'):\")\n",
    "categorical_missing = train[categorical_cols].isnull().sum()\n",
    "cols_to_impute_cat = categorical_missing[categorical_missing > 0].index.tolist()\n",
    "\n",
    "for col in cols_to_impute_cat:\n",
    "    # Create 'MISSING' category\n",
    "    train[col].fillna('MISSING', inplace=True)\n",
    "    test[col].fillna('MISSING', inplace=True)\n",
    "    pct = 100 * train[col].isna().sum() / len(train)\n",
    "\n",
    "print(f\"   Imputed {len(cols_to_impute_cat)} categorical columns\")\n",
    "\n",
    "# Check for remaining missing values\n",
    "remaining_missing = train.isnull().sum().sum() + test.isnull().sum().sum()\n",
    "print(f\"\\n✓ Remaining missing values: {remaining_missing}\")\n",
    "print(\"✓ Imputation complete\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 5: Remove High-Missing Columns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 5: REMOVE HIGH-MISSING COLUMNS\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Columns with >70% missing (before imputation)\n",
    "missing_pct_original = 100 * pd.read_csv(data_dir / 'application_train.csv').isnull().sum() / len(train)\n",
    "cols_to_drop = missing_pct_original[missing_pct_original > 70].index.tolist()\n",
    "\n",
    "print(f\"\\nColumns to drop (>70% missing): {len(cols_to_drop)}\")\n",
    "for col in cols_to_drop:\n",
    "    if col in train.columns:\n",
    "        print(f\"  - {col} ({missing_pct_original[col]:.1f}%)\")\n",
    "        train.drop(col, axis=1, inplace=True)\n",
    "        test.drop(col, axis=1, inplace=True)\n",
    "\n",
    "print(f\"\\n✓ Removed {len(cols_to_drop)} columns\")\n",
    "print(f\"Train shape: {train.shape}\")\n",
    "print(f\"Test shape:  {test.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 6: Aggregate Transactional Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 6: AGGREGATE TRANSACTIONAL DATA\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# ===== BUREAU DATA =====\n",
    "print(\"\\n1. Bureau Data:\")\n",
    "try:\n",
    "    bureau = pd.read_csv(data_dir / 'bureau.csv')\n",
    "    print(f\"   Loaded: {bureau.shape[0]:,} rows\")\n",
    "    \n",
    "    bureau_agg = bureau.groupby('SK_ID_CURR').agg({\n",
    "        'SK_ID_BUREAU': 'count',\n",
    "        'DAYS_CREDIT': ['min', 'max', 'mean'],\n",
    "        'CREDIT_DAY_OVERDUE': ['min', 'max', 'mean'],\n",
    "        'AMT_CREDIT_MAX_OVERDUE': ['sum', 'max', 'mean'],\n",
    "        'AMT_CREDIT_SUM': ['sum', 'mean', 'max'],\n",
    "        'AMT_CREDIT_SUM_LIMIT': ['sum', 'mean'],\n",
    "        'CREDIT_ACTIVE': lambda x: (x == 'Active').sum()\n",
    "    }).reset_index()\n",
    "    \n",
    "    # Flatten column names\n",
    "    bureau_agg.columns = ['_'.join(col).strip('_') if col[1] else col[0] \n",
    "                           for col in bureau_agg.columns.values]\n",
    "    bureau_agg.columns = ['bureau_' + c if c != 'SK_ID_CURR' else c \n",
    "                          for c in bureau_agg.columns]\n",
    "    \n",
    "    print(f\"   Aggregated: {bureau_agg.shape[0]:,} unique clients, {bureau_agg.shape[1]} features\")\n",
    "    \n",
    "    train = train.merge(bureau_agg, on='SK_ID_CURR', how='left')\n",
    "    test = test.merge(bureau_agg, on='SK_ID_CURR', how='left')\n",
    "    print(f\"   ✓ Merged with train/test\")\n",
    "except Exception as e:\n",
    "    print(f\"   ⚠️ Error: {e}\")\n",
    "\n",
    "# ===== PREVIOUS APPLICATIONS =====\n",
    "print(\"\\n2. Previous Applications:\")\n",
    "try:\n",
    "    prev_app = pd.read_csv(data_dir / 'previous_application.csv')\n",
    "    print(f\"   Loaded: {prev_app.shape[0]:,} rows\")\n",
    "    \n",
    "    prev_agg = prev_app.groupby('SK_ID_CURR').agg({\n",
    "        'SK_ID_PREV': 'count',\n",
    "        'NAME_CONTRACT_STATUS': lambda x: (x == 'Approved').sum(),\n",
    "        'AMT_APPLICATION': ['sum', 'mean', 'max'],\n",
    "        'AMT_CREDIT': ['sum', 'mean', 'max'],\n",
    "        'DAYS_DECISION': ['min', 'mean'],\n",
    "    }).reset_index()\n",
    "    \n",
    "    prev_agg.columns = ['_'.join(col).strip('_') if col[1] else col[0] \n",
    "                        for col in prev_agg.columns.values]\n",
    "    prev_agg.columns = ['prev_app_' + c if c != 'SK_ID_CURR' else c \n",
    "                        for c in prev_agg.columns]\n",
    "    \n",
    "    print(f\"   Aggregated: {prev_agg.shape[0]:,} unique clients, {prev_agg.shape[1]} features\")\n",
    "    \n",
    "    train = train.merge(prev_agg, on='SK_ID_CURR', how='left')\n",
    "    test = test.merge(prev_agg, on='SK_ID_CURR', how='left')\n",
    "    print(f\"   ✓ Merged with train/test\")\n",
    "except Exception as e:\n",
    "    print(f\"   ⚠️ Error: {e}\")\n",
    "\n",
    "# ===== CREDIT CARD BALANCE =====\n",
    "print(\"\\n3. Credit Card Balance:\")\n",
    "try:\n",
    "    cc_balance = pd.read_csv(data_dir / 'credit_card_balance.csv')\n",
    "    print(f\"   Loaded: {cc_balance.shape[0]:,} rows\")\n",
    "    \n",
    "    cc_agg = cc_balance.groupby('SK_ID_CURR').agg({\n",
    "        'MONTHS_BALANCE': 'count',\n",
    "        'AMT_BALANCE': ['mean', 'max', 'min'],\n",
    "        'AMT_CREDIT_LIMIT_ACTUAL': ['mean', 'max'],\n",
    "        'STATUS': lambda x: (x == '0').sum()  # Paid in full\n",
    "    }).reset_index()\n",
    "    \n",
    "    cc_agg.columns = ['_'.join(col).strip('_') if col[1] else col[0] \n",
    "                      for col in cc_agg.columns.values]\n",
    "    cc_agg.columns = ['cc_' + c if c != 'SK_ID_CURR' else c \n",
    "                      for c in cc_agg.columns]\n",
    "    \n",
    "    print(f\"   Aggregated: {cc_agg.shape[0]:,} unique clients, {cc_agg.shape[1]} features\")\n",
    "    \n",
    "    train = train.merge(cc_agg, on='SK_ID_CURR', how='left')\n",
    "    test = test.merge(cc_agg, on='SK_ID_CURR', how='left')\n",
    "    print(f\"   ✓ Merged with train/test\")\n",
    "except Exception as e:\n",
    "    print(f\"   ⚠️ Error: {e}\")\n",
    "\n",
    "# ===== INSTALLMENT PAYMENTS =====\n",
    "print(\"\\n4. Installment Payments:\")\n",
    "try:\n",
    "    installments = pd.read_csv(data_dir / 'installments_payments.csv')\n",
    "    print(f\"   Loaded: {installments.shape[0]:,} rows\")\n",
    "    \n",
    "    inst_agg = installments.groupby('SK_ID_CURR').agg({\n",
    "        'SK_ID_PREV': 'nunique',\n",
    "        'NUM_INSTALMENT_VERSION': 'max',\n",
    "        'DAYS_INSTALMENT': ['min', 'mean', 'max'],\n",
    "        'AMT_INSTALMENT': ['sum', 'mean', 'max'],\n",
    "        'AMT_PAYMENT': ['sum', 'mean', 'max']\n",
    "    }).reset_index()\n",
    "    \n",
    "    inst_agg.columns = ['_'.join(col).strip('_') if col[1] else col[0] \n",
    "                        for col in inst_agg.columns.values]\n",
    "    inst_agg.columns = ['inst_' + c if c != 'SK_ID_CURR' else c \n",
    "                        for c in inst_agg.columns]\n",
    "    \n",
    "    print(f\"   Aggregated: {inst_agg.shape[0]:,} unique clients, {inst_agg.shape[1]} features\")\n",
    "    \n",
    "    train = train.merge(inst_agg, on='SK_ID_CURR', how='left')\n",
    "    test = test.merge(inst_agg, on='SK_ID_CURR', how='left')\n",
    "    print(f\"   ✓ Merged with train/test\")\n",
    "except Exception as e:\n",
    "    print(f\"   ⚠️ Error: {e}\")\n",
    "\n",
    "print(f\"\\n✓ Final Train shape: {train.shape}\")\n",
    "print(f\"✓ Final Test shape:  {test.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 7: Domain-Specific Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 7: DOMAIN-SPECIFIC FEATURE ENGINEERING\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# ===== DEBT-TO-INCOME RATIO =====\n",
    "print(\"\\n1. Debt-to-Income Ratio:\")\n",
    "train['debt_to_income'] = train['AMT_CREDIT'] / (train['AMT_INCOME_TOTAL'] + 1)\n",
    "test['debt_to_income'] = test['AMT_CREDIT'] / (test['AMT_INCOME_TOTAL'] + 1)\n",
    "print(f\"   ✓ Created\")\n",
    "\n",
    "# ===== ANNUITY-TO-INCOME RATIO =====\n",
    "print(\"\\n2. Annuity-to-Income Ratio:\")\n",
    "train['annuity_to_income'] = train['AMT_ANNUITY'] / (train['AMT_INCOME_TOTAL'] + 1)\n",
    "test['annuity_to_income'] = test['AMT_ANNUITY'] / (test['AMT_INCOME_TOTAL'] + 1)\n",
    "print(f\"   ✓ Created\")\n",
    "\n",
    "# ===== CREDIT-TO-ANNUITY RATIO =====\n",
    "print(\"\\n3. Credit-to-Annuity Ratio:\")\n",
    "train['credit_to_annuity'] = train['AMT_CREDIT'] / (train['AMT_ANNUITY'] + 1)\n",
    "test['credit_to_annuity'] = test['AMT_CREDIT'] / (test['AMT_ANNUITY'] + 1)\n",
    "print(f\"   ✓ Created\")\n",
    "\n",
    "# ===== AGE IN YEARS =====\n",
    "print(\"\\n4. Age in Years:\")\n",
    "train['age_years'] = np.abs(train['DAYS_BIRTH'] / 365.25)\n",
    "test['age_years'] = np.abs(test['DAYS_BIRTH'] / 365.25)\n",
    "print(f\"   ✓ Created\")\n",
    "\n",
    "# ===== EMPLOYMENT TENURE IN YEARS =====\n",
    "print(\"\\n5. Employment Tenure in Years:\")\n",
    "train['employment_years'] = np.abs(train['DAYS_EMPLOYED'] / 365.25)\n",
    "test['employment_years'] = np.abs(test['DAYS_EMPLOYED'] / 365.25)\n",
    "print(f\"   ✓ Created\")\n",
    "\n",
    "# ===== INCOME PER FAMILY MEMBER =====\n",
    "print(\"\\n6. Income per Family Member:\")\n",
    "train['income_per_member'] = train['AMT_INCOME_TOTAL'] / (train['CNT_FAM_MEMBERS'] + 1)\n",
    "test['income_per_member'] = test['AMT_INCOME_TOTAL'] / (test['CNT_FAM_MEMBERS'] + 1)\n",
    "print(f\"   ✓ Created\")\n",
    "\n",
    "# ===== EXT_SOURCE AVERAGE =====\n",
    "print(\"\\n7. External Source Average:\")\ntrain['ext_source_avg'] = train[['EXT_SOURCE_1', 'EXT_SOURCE_2', 'EXT_SOURCE_3']].mean(axis=1)\n",
    "test['ext_source_avg'] = test[['EXT_SOURCE_1', 'EXT_SOURCE_2', 'EXT_SOURCE_3']].mean(axis=1)\n",
    "print(f\"   ✓ Created\")\n",
    "\n",
    "print(f\"\\n✓ {7} domain features created\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 8: Handle Outliers & Skewed Distributions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 8: OUTLIER & SKEWNESS HANDLING\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Identify right-skewed distributions\n",
    "numeric_cols_all = train.select_dtypes(include=['int64', 'float64']).columns\n",
    "numeric_cols_all = [c for c in numeric_cols_all if c not in ['SK_ID_CURR', 'TARGET']]\n",
    "\n",
    "# Log transform for right-skewed features (with positive values)\n",
    "skewed_features = []\n",
    "for col in numeric_cols_all:\n",
    "    # Check if all values are positive\n",
    "    if train[col].min() > 0:\n",
    "        # Calculate skewness\n",
    "        skewness = train[col].skew()\n",
    "        if skewness > 1:  # Right-skewed threshold\n",
    "            skewed_features.append(col)\n",
    "            train[col + '_log'] = np.log1p(train[col])\n",
    "            test[col + '_log'] = np.log1p(test[col])\n",
    "\n",
    "print(f\"\\nLog-transformed {len(skewed_features)} right-skewed features:\")\n",
    "for feat in skewed_features[:10]:  # Show first 10\n",
    "    print(f\"  - {feat}\")\n",
    "if len(skewed_features) > 10:\n",
    "    print(f\"  ... and {len(skewed_features) - 10} more\")\n",
    "\n",
    "# Winsorization for extreme outliers (optional - only for linear models)\n",
    "print(f\"\\n✓ Outliers handled (kept for tree models, can winsorize for linear)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 9: Categorical Encoding"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"STEP 9: CATEGORICAL ENCODING\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Get categorical columns\n",
    "categorical_cols = train.select_dtypes(include=['object']).columns.tolist()\n",
    "categorical_cols = [c for c in categorical_cols if c != 'SK_ID_CURR']\n",
    "\n",
    "print(f\"\\nCategorical columns to encode: {len(categorical_cols)}\")\n",
    "\n",
    "# ===== LABEL ENCODING FOR BINARY CATEGORIES =====\n",
    "binary_cols = []\n",
    "le_dict = {}\n",
    "\n",
    "for col in categorical_cols:\n",
    "    n_unique = train[col].nunique()\n",
    "    \n",
    "    if n_unique == 2:\n",
    "        # Binary encoding\n",
    "        le = LabelEncoder()\n",
    "        train[col] = le.fit_transform(train[col].astype(str))\n",
    "        test[col] = le.transform(test[col].astype(str))\n",
    "        le_dict[col] = le\n",
    "        binary_cols.append(col)\n",
    "\n",
    "print(f\"\\n1. Binary Encoding: {len(binary_cols)} columns\")\n",
    "for col in binary_cols:\n",
    "    print(f\"   - {col}\")\n",
    "\n",
    "# ===== ONE-HOT ENCODING FOR MULTI-CLASS CATEGORIES =====\n",
    "multi_class_cols = [c for c in categorical_cols if train[c].nunique() > 2]\n",
    "\n",
    "print(f\"\\n2. One-Hot Encoding: {len(multi_class_cols)} columns\")\n",
    "\n",
    "# One-hot encode\n",
    "train_encoded = pd.get_dummies(train[multi_class_cols], drop_first=True, prefix=multi_class_cols)\n",
    "test_encoded = pd.get_dummies(test[multi_class_cols], drop_first=True, prefix=multi_class_cols)\n",
    "\n",
    "# Align test with train (some categories might not appear in test)\n",
    "test_encoded = test_encoded.reindex(columns=train_encoded.columns, fill_value=0)\n",
    "\n",
    "# Drop original categorical columns and add encoded ones\n",
    "train = train.drop(multi_class_cols, axis=1)\n",
    "test = test.drop(multi_class_cols, axis=1)\n",
    "\n",
    "train = pd.concat([train, train_encoded], axis=1)\n",
    "test = pd.concat([test, test_encoded], axis=1)\n",
    "\n",
    "print(f\"   Created {train_encoded.shape[1]} one-hot encoded columns\")\n",
    "\n",
    "print(f\"\\n✓ Encoding complete\")\n",
    "print(f\"  Train shape: {train.shape}\")\n",
    "print(f\"  Test shape:  {test.shape}\")"
   ]
  },
